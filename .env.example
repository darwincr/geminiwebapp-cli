# geminiwebapp-cli environment variables
#
# The CLI automatically loads .env from the current working directory.
# Existing shell/system environment variables take precedence over .env values.

# Default browser session/profile name.
GEMINIWEBAPP_CLI_SESSION=default

# State root for browser profiles and worker sockets.
# Default when unset: ~/.geminiwebapp-cli
GEMINIWEBAPP_CLI_HOME=

# Run browser automation headlessly when set to 1, true, yes, or on.
GEMINIWEBAPP_CLI_HEADLESS=

# Python logging level.
GEMINIWEBAPP_CLI_LOG=INFO

# Enable live Gemini smoke tests when set to 1, true, yes, or on.
GEMINIWEBAPP_CLI_LIVE=

# Session/profile name used by live smoke tests.
# Default when unset: GEMINIWEBAPP_CLI_SESSION, or default
GEMINIWEBAPP_CLI_LIVE_SESSION=

# Existing Gemini music chat id, /app path, or full URL for the live music
# download smoke test. The test downloads existing audio and does not generate
# new music.
GEMINIWEBAPP_CLI_LIVE_MUSIC_CHAT=
